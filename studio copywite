<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Studio Copywrite — Les mots qui font acheter</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

  :root {
    --bg: #16050F;
    --surface: #200A17;
    --surface2: #2C0F20;
    --border: #4A1836;
    --magenta: #E11D82;
    --magenta-light: #FF6FB5;
    --magenta-glow: rgba(225, 29, 130, 0.15);
    --pink: #F7A8C4;
    --pink-glow: rgba(247, 168, 196, 0.10);
    --text: #FBF3F8;
    --text-muted: #C9A9BE;
    --text-dim: #8A6479;
    --sans: #F04E4E;
    --sans-bg: rgba(240, 78, 78, 0.12);
    --sans-border: rgba(240, 78, 78, 0.35);
    --avec: #10B981;
    --avec-bg: rgba(16, 185, 129, 0.12);
    --avec-border: rgba(16, 185, 129, 0.35);
    --tag-bg: rgba(225, 29, 130, 0.14);
    --tag-border: rgba(225, 29, 130, 0.4);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Space Grotesk', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(225, 29, 130, 0.10) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 85% 100%, rgba(247, 168, 196, 0.06) 0%, transparent 60%);
  }

  /* HEADER */
  .header {
    padding: 24px 32px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(22, 5, 15, 0.85);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo { display: flex; align-items: center; gap: 12px; }

  .logo-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--magenta), var(--pink));
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
  }

  .logo-text {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .logo-text span { color: var(--magenta-light); }

  .key-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 8px 16px;
    border-radius: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .key-btn:hover { border-color: var(--magenta); color: var(--text); }
  .key-btn.active { border-color: var(--avec); color: var(--avec); }

  /* HERO */
  .hero { text-align: center; padding: 60px 32px 44px; max-width: 720px; margin: 0 auto; }

  .hero-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pink);
    margin-bottom: 18px;
  }

  .hero h1 {
    font-size: clamp(30px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.12;
    margin-bottom: 16px;
    background: linear-gradient(135deg, var(--text) 0%, var(--magenta-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero p { font-size: 15px; color: var(--text-muted); line-height: 1.65; }

  /* PRINCIPLES LEGEND */
  .principles-section { max-width: 920px; margin: 0 auto 44px; padding: 0 32px; }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 16px;
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
  }

  .principle-pill {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    transition: all 0.2s;
  }

  .principle-pill:hover { border-color: var(--magenta); background: var(--magenta-glow); }

  .principle-num {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--magenta-light);
    opacity: 0.7;
    min-width: 16px;
    margin-top: 2px;
  }

  .principle-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 2px; }
  .principle-desc { font-size: 11px; color: var(--text-dim); line-height: 1.4; }

  /* MAIN FORM */
  .main-form { max-width: 920px; margin: 0 auto; padding: 0 32px 48px; }

  .form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 24px;
  }

  .form-row { margin-bottom: 20px; }

  label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 8px;
  }

  .label-hint { color: var(--text-dim); font-weight: 400; text-transform: none; letter-spacing: 0; }

  textarea, input[type="text"], select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    padding: 14px 16px;
    transition: border-color 0.2s;
    resize: none;
    outline: none;
  }

  textarea:focus, input[type="text"]:focus, select:focus { border-color: var(--magenta); }
  textarea { min-height: 110px; line-height: 1.5; }
  select { cursor: pointer; }
  select option { background: var(--surface2); }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .arch-tag {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
    display: inline-block;
  }

  .arch-tag:hover { border-color: var(--magenta); color: var(--text); }
  .arch-tag.selected { background: var(--magenta); border-color: var(--magenta); color: white; }

  .generate-btn {
    width: 100%;
    padding: 18px;
    background: linear-gradient(135deg, var(--magenta) 0%, #C81A73 50%, var(--pink) 100%);
    border: none;
    border-radius: 12px;
    color: white;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .generate-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 32px rgba(225, 29, 130, 0.4); }
  .generate-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .generate-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s;
  }

  .generate-btn:hover::after { transform: translateX(100%); }

  /* LOADING */
  .loading { display: none; text-align: center; padding: 48px; }
  .loading.active { display: block; }

  .pulse-ring {
    width: 60px; height: 60px; border-radius: 50%;
    border: 2px solid var(--magenta); border-top-color: transparent;
    animation: spin 1s linear infinite; margin: 0 auto 16px;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  .loading p { color: var(--text-muted); font-size: 14px; font-style: italic; }

  /* RESULTS */
  .results { display: none; }
  .results.active { display: block; }

  .results-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }

  .results-title {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--magenta-light);
  }

  .copy-all-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 8px 14px;
    border-radius: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .copy-all-btn:hover { border-color: var(--magenta); color: var(--text); }

  .result-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px;
    margin-bottom: 16px;
    position: relative;
    transition: border-color 0.2s;
  }

  .result-card:hover { border-color: var(--magenta); }

  .result-num {
    position: absolute; top: 20px; right: 20px;
    font-family: 'Space Mono', monospace; font-size: 10px; color: var(--text-dim); opacity: 0.4;
  }

  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 16px;
  }

  .compare-col { }

  .compare-label {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    margin-bottom: 10px;
  }

  .compare-label.sans { background: var(--sans-bg); border: 1px solid var(--sans-border); color: var(--sans); }
  .compare-label.avec { background: var(--avec-bg); border: 1px solid var(--avec-border); color: var(--avec); }

  .compare-text {
    font-size: 13px;
    line-height: 1.6;
    padding: 14px;
    border-radius: 10px;
    background: var(--bg);
  }

  .compare-col.sans-col .compare-text { color: var(--text-dim); border: 1px solid var(--sans-border); }
  .compare-col.avec-col .compare-text { color: var(--text); border: 1px solid var(--avec-border); white-space: pre-wrap; }

  .principle-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 14px; }

  .principle-tag {
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    color: var(--magenta-light);
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: 20px;
    text-transform: uppercase;
  }

  .result-why {
    font-size: 12px;
    color: var(--pink);
    margin-bottom: 14px;
    font-style: italic;
    opacity: 0.9;
    line-height: 1.5;
  }

  .result-actions { display: flex; gap: 8px; }

  .result-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 7px 14px;
    border-radius: 8px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .result-btn:hover { border-color: var(--magenta-light); color: var(--text); }

  @media (max-width: 640px) {
    .header { padding: 16px 20px; }
    .hero { padding: 40px 20px 32px; }
    .principles-section, .main-form { padding: 0 20px 32px; }
    .form-grid { grid-template-columns: 1fr; }
    .form-card { padding: 20px; }
    .principles-grid { grid-template-columns: 1fr; }
    .compare-grid { grid-template-columns: 1fr; }
  }

  /* MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(22, 5, 15, 0.88); backdrop-filter: blur(8px);
    z-index: 200; align-items: center; justify-content: center;
  }

  .modal-overlay.active { display: flex; }

  .modal {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 32px; width: 90%; max-width: 440px;
  }

  .modal h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
  .modal p { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; line-height: 1.5; }

  .modal input {
    width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 10px;
    color: var(--text); font-family: 'Space Mono', monospace; font-size: 13px;
    padding: 14px 16px; outline: none; margin-bottom: 16px;
  }

  .modal input:focus { border-color: var(--magenta); }

  .modal-actions { display: flex; gap: 10px; }

  .modal-save {
    flex: 1; padding: 12px; background: var(--magenta); border: none; border-radius: 10px;
    color: white; font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 14px; cursor: pointer;
  }

  .modal-cancel {
    padding: 12px 20px; background: var(--surface2); border: 1px solid var(--border);
    border-radius: 10px; color: var(--text-muted); font-family: 'Space Grotesk', sans-serif;
    font-size: 14px; cursor: pointer;
  }

  /* TOAST */
  .toast {
    position: fixed; bottom: 32px; right: 32px;
    background: var(--surface2); border: 1px solid var(--magenta); color: var(--text);
    padding: 12px 20px; border-radius: 10px; font-size: 13px; z-index: 300;
    transform: translateY(80px); opacity: 0; transition: all 0.3s;
  }

  .toast.show { transform: translateY(0); opacity: 1; }
</style>
</head>
<body>

<header class="header">
  <div class="logo">
    <div class="logo-icon">💸</div>
    <div class="logo-text">Studio <span>Copywrite</span></div>
  </div>
  <button class="key-btn" id="keyBtn" onclick="openModal()">
    <span id="keyStatus">🔑</span>
    <span id="keyLabel">Clé API</span>
  </button>
</header>

<section class="hero">
  <div class="hero-eyebrow">Les mots qui font acheter</div>
  <h1>Écris comme tu parles. Vends la transformation.</h1>
  <p>Colle ton texte brut, ton idée, ton offre — Studio Copywrite le réécrit comme un texto envoyé à une amie, avec les 9 principes de l'atelier. Chaque version est taguée avec les principes qu'elle applique.</p>
</section>

<section class="principles-section">
  <div class="section-label">Les 9 principes de l'Atelier — checklist</div>
  <div class="principles-grid" id="principlesLegend"></div>
</section>

<div class="main-form">
  <div class="form-card">

    <div class="form-row">
      <label>Ton texte brut / ton idée <span class="label-hint">(colle ta version "sans copy")</span></label>
      <textarea id="subject" placeholder="Ex: Je propose un accompagnement de 8 semaines pour aider les entrepreneures à structurer leur activité sur Instagram. Nous travaillons sur le positionnement, la stratégie de contenu et la mise en place d'un tunnel de vente..."></textarea>
    </div>

    <div class="form-grid">
      <div class="form-row">
        <label>Niche / Domaine</label>
        <input type="text" id="niche" placeholder="Ex: Coaching business, Fitness, Beauté...">
      </div>
      <div class="form-row">
        <label>Format cible</label>
        <select id="format">
          <option value="post">Post Instagram / caption</option>
          <option value="dm">Message privé / DM</option>
          <option value="email">Email de vente</option>
          <option value="landing">Page de vente</option>
          <option value="story">Story / texto rapide</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <label>Qui parle à qui ? <span class="label-hint">(pour caler le ton)</span></label>
      <input type="text" id="audience" placeholder="Ex: une coach à sa cliente idéale, épuisée de poster dans le vide">
    </div>

    <div class="form-row">
      <label>Principes à forcer <span class="label-hint">(ou laisse Auto — l'IA applique la checklist entière)</span></label>
      <div class="archetype-selector" id="principleSelector" style="display:flex;flex-wrap:wrap;gap:8px;">
        <div class="arch-tag selected" data-value="auto" onclick="togglePrinciple(this)" style="background:linear-gradient(135deg, var(--magenta), var(--pink));border-color:transparent;color:white;">⚡ Auto (toute la checklist)</div>
      </div>
    </div>

    <div class="form-row">
      <label>Nombre de versions</label>
      <select id="versionCount">
        <option value="2">2 versions</option>
        <option value="3" selected>3 versions</option>
        <option value="5">5 versions</option>
      </select>
    </div>

    <button class="generate-btn" id="generateBtn" onclick="generate()">
      Transformer en texte qui vend
    </button>
  </div>

  <div class="loading" id="loading">
    <div class="pulse-ring"></div>
    <p>Réécriture façon SMS à une amie...</p>
  </div>

  <div class="results" id="results">
    <div class="results-header">
      <div class="results-title">Versions "avec copy"</div>
      <button class="copy-all-btn" onclick="copyAll()">Tout copier</button>
    </div>
    <div id="resultsContainer"></div>
  </div>
</div>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <h3>🔑 Clé API Vertex AI</h3>
    <p>Ta clé est stockée localement dans ton navigateur. Elle ne quitte jamais ton appareil.</p>
    <input type="password" id="apiKeyInput" placeholder="AQ...">
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeModal()">Annuler</button>
      <button class="modal-save" onclick="saveKey()">Enregistrer</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const PRINCIPLES = [
  { id: 'start_with_bang', name: 'Start With a Bang', desc: "Toujours commencer DANS l'action, jamais en préambule" },
  { id: 'carte_bleue', name: 'La Carte Bleue', desc: "Les gens achètent avec leurs émotions, pas leur raison" },
  { id: 'sms_amie', name: 'Le SMS à une Amie', desc: "Écris comme tu parles, jamais corporate" },
  { id: 'vends_transformation', name: 'Vends la Transformation', desc: "On ne vend pas le produit mais sa transfo, pas le processus" },
  { id: 'rythme', name: 'Le Rythme', desc: "Fais respirer ton texte avec des phrases courtes et des retours à la ligne" },
  { id: 'analogies', name: 'Les Analogies', desc: "Fais des comparaisons concrètes pour rendre l'abstrait tangible" },
  { id: 'roi', name: 'Le ROI', desc: "Accroche sur le retour sur investissement, chiffré et concret" },
  { id: 'vers_infini', name: "Vers l'Infini...", desc: "Chaque phrase doit donner envie de lire la suivante" },
  { id: 'cta_unique', name: 'Le CTA Unique', desc: 'Un seul call-to-action clair par texte, jamais trois' },
];

const legendEl = document.getElementById('principlesLegend');
PRINCIPLES.forEach((p, i) => {
  legendEl.innerHTML += `
    <div class="principle-pill">
      <div class="principle-num">${String(i+1).padStart(2,'0')}</div>
      <div>
        <div class="principle-name">${p.name}</div>
        <div class="principle-desc">${p.desc}</div>
      </div>
    </div>`;
});

const selectorEl = document.getElementById('principleSelector');
PRINCIPLES.forEach(p => {
  const tag = document.createElement('div');
  tag.className = 'arch-tag';
  tag.dataset.value = p.id;
  tag.textContent = p.name;
  tag.onclick = () => togglePrinciple(tag);
  selectorEl.appendChild(tag);
});

function togglePrinciple(el) {
  if (el.dataset.value === 'auto') {
    document.querySelectorAll('#principleSelector .arch-tag:not([data-value="auto"])').forEach(t => t.classList.remove('selected'));
    el.classList.add('selected');
    return;
  }
  const autoTag = document.querySelector('#principleSelector .arch-tag[data-value="auto"]');
  autoTag.classList.remove('selected');
  el.classList.toggle('selected');
  if (!document.querySelector('#principleSelector .arch-tag.selected')) {
    autoTag.classList.add('selected');
  }
}

function openModal() {
  const stored = localStorage.getItem('studio_copywrite_key');
  if (stored) document.getElementById('apiKeyInput').value = stored;
  document.getElementById('modalOverlay').classList.add('active');
}

function closeModal() { document.getElementById('modalOverlay').classList.remove('active'); }

function saveKey() {
  const key = document.getElementById('apiKeyInput').value.trim();
  if (!key) return;
  localStorage.setItem('studio_copywrite_key', key);
  updateKeyStatus();
  closeModal();
  showToast('✅ Clé API enregistrée');
}

function updateKeyStatus() {
  const key = localStorage.getItem('studio_copywrite_key');
  const btn = document.getElementById('keyBtn');
  const label = document.getElementById('keyLabel');
  if (key) { btn.classList.add('active'); label.textContent = 'Clé active'; }
  else { btn.classList.remove('active'); label.textContent = 'Clé API'; }
}
updateKeyStatus();

async function generate() {
  const key = localStorage.getItem('studio_copywrite_key');
  if (!key) { openModal(); return; }

  const subject = document.getElementById('subject').value.trim();
  if (!subject) { showToast("⚠️ Colle d'abord ton texte brut"); return; }

  const niche = document.getElementById('niche').value.trim() || 'général';
  const audience = document.getElementById('audience').value.trim() || 'son audience idéale';
  const format = document.getElementById('format').value;
  const versionCount = document.getElementById('versionCount').value;

  const selectedPrinciples = [...document.querySelectorAll('#principleSelector .arch-tag.selected:not([data-value="auto"])')].map(t => t.dataset.value);
  const autoMode = document.querySelector('#principleSelector .arch-tag[data-value="auto"]').classList.contains('selected');

  const principleList = PRINCIPLES.map(p => `- ${p.id}: ${p.name} — ${p.desc}`).join('\n');
  const principleInstruction = autoMode
    ? 'Applique la checklist complète des 9 principes à chaque version (pas besoin de tous les nommer, mais le texte doit les respecter).'
    : `Force en priorité ces principes: ${selectedPrinciples.join(', ')}, en plus des bases (SMS à une amie, rythme, CTA unique).`;

  document.getElementById('loading').classList.add('active');
  document.getElementById('results').classList.remove('active');
  document.getElementById('generateBtn').disabled = true;

  const formatMap = {
    post: 'Post Instagram / caption',
    dm: 'Message privé / DM',
    email: 'Email de vente',
    landing: 'Page de vente',
    story: 'Story / texto rapide'
  };

  const prompt = `Tu es copywriter francophone, formé sur l'atelier "Les mots qui font acheter". Tu appliques STRICTEMENT ces 9 principes, tirés de cet atelier:

${principleList}

RÈGLE D'OR: le texte final doit sonner comme un texto envoyé à une amie proche — jamais corporate, jamais "je vous accompagne dans le développement stratégique de votre activité". Toujours concret, incarné, avec des détails sensoriels et des chiffres quand c'est pertinent.

MISSION: transforme ce texte brut ("sans copy") en exactement ${versionCount} versions "avec copy" différentes, en variant l'angle d'attaque (analogie, ROI, confession, transformation, etc.) mais en gardant toujours le fond du message intact.

TEXTE BRUT ("sans copy"):
"${subject}"

NICHE: ${niche}
QUI PARLE À QUI: ${audience}
FORMAT CIBLE: ${formatMap[format]}
${principleInstruction}

Pour chaque version, fournis:
1. "avant": le texte brut original (raccourci si besoin, tel quel, ne pas réécrire)
2. "apres": la version "avec copy" complète et prête à publier, au format ${formatMap[format]} (rythme aéré avec retours à la ligne si pertinent, UN SEUL call-to-action)
3. "principes": liste des IDs de principes que cette version applique particulièrement (2 à 4 IDs)
4. "pourquoi": 1-2 phrases expliquant pourquoi ça vend, en langage simple

Réponds UNIQUEMENT en JSON valide, sans markdown, sans backticks:
{
  "versions": [
    {
      "id": 1,
      "avant": "texte original",
      "apres": "texte réécrit avec copy",
      "principes": ["principle_id_1", "principle_id_2"],
      "pourquoi": "explication courte"
    }
  ]
}`;

  try {
    const url = `https://europe-west1-aiplatform.googleapis.com/v1/publishers/google/models/gemini-2.5-flash:generateContent?key=${key}`;
    const response = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{ role: 'user', parts: [{ text: prompt }] }],
        generationConfig: {
          temperature: 0.85,
          maxOutputTokens: 4096,
          responseMimeType: 'application/json'
        }
      })
    });

    if (!response.ok) {
      const err = await response.json();
      throw new Error(err.error?.message || 'Erreur API');
    }

    const data = await response.json();
    const raw = data.candidates?.[0]?.content?.parts?.[0]?.text;
    if (!raw) throw new Error('Réponse vide');

    const clean = raw.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);
    renderResults(parsed.versions);

  } catch (err) {
    showToast('❌ Erreur: ' + err.message);
    console.error(err);
  } finally {
    document.getElementById('loading').classList.remove('active');
    document.getElementById('generateBtn').disabled = false;
  }
}

function renderResults(versions) {
  const container = document.getElementById('resultsContainer');
  container.innerHTML = '';

  versions.forEach((v, i) => {
    const tagNames = (v.principes || []).map(id => {
      const found = PRINCIPLES.find(p => p.id === id);
      return found ? `<span class="principle-tag">${found.name}</span>` : '';
    }).join('');

    const card = document.createElement('div');
    card.className = 'result-card';
    card.innerHTML = `
      <div class="result-num">#${i+1}</div>
      <div class="principle-tags">${tagNames}</div>
      <div class="compare-grid">
        <div class="compare-col sans-col">
          <span class="compare-label sans">Sans copy</span>
          <div class="compare-text">${escapeHtml(v.avant)}</div>
        </div>
        <div class="compare-col avec-col">
          <span class="compare-label avec">Avec copy</span>
          <div class="compare-text">${escapeHtml(v.apres)}</div>
        </div>
      </div>
      ${v.pourquoi ? `<div class="result-why">🧠 ${escapeHtml(v.pourquoi)}</div>` : ''}
      <div class="result-actions">
        <button class="result-btn" onclick="copyApres(${i})">Copier "avec copy"</button>
      </div>`;
    container.appendChild(card);
  });

  window._versions = versions;
  document.getElementById('results').classList.add('active');
  document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
}

function escapeHtml(str) {
  return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
}

function copyApres(i) { copyText(window._versions[i].apres); }

function copyAll() {
  if (!window._versions) return;
  const text = window._versions.map((v, i) => `=== VERSION ${i+1} ===\n\n${v.apres}`).join('\n\n---\n\n');
  copyText(text);
}

function copyText(text) {
  navigator.clipboard.writeText(text).then(() => showToast('✅ Copié !'));
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
</body>
</html>
