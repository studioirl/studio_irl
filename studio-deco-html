// ─────────────────────────────────────────────
// STORYBOARD RENDER
// ─────────────────────────────────────────────
function renderStoryboard() {
  const list = document.getElementById('stepsList');
  list.innerHTML = '';
  steps.forEach((step, i) => {
    const div = document.createElement('div');
    div.className = 'step-item';
    div.innerHTML = `
      <div class="step-num">${i + 1}</div>
      <div class="step-content">
        <input class="step-name" value="${escHtml(step.name)}" onchange="steps[${i}].name=this.value" style="border:none;background:transparent;font-weight:500;font-size:14px;font-family:'DM Sans',sans-serif;width:100%;outline:none;color:#2C2C2A;" />
        <textarea class="step-desc" onchange="steps[${i}].description=this.value" rows="2">${escHtml(step.description)}</textarea>
      </div>
      <button class="step-delete" onclick="deleteStep(${i})">×</button>
    `;
    list.appendChild(div);
  });
  document.getElementById('storyboardSection').classList.add('visible');
  document.getElementById('generateRow').style.display = 'flex';
  renderProgressDots();
}

function addStep() {
  steps.push({ name: 'Nouvelle étape', description: 'Décrivez ce que font les parents dans cette scène...' });
  renderStoryboard();
}

function deleteStep(i) {
  steps.splice(i, 1);
  renderStoryboard();
}

function escHtml(s) {
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ─────────────────────────────────────────────
// GENERATE SEQUENCE
// ─────────────────────────────────────────────
async function generateSequence() {
  const key = getApiKey();
  if (!key) return showError('Veuillez entrer votre clé API.');
  if (!images.inspi) return showError("Image d'inspiration manquante.");
  if (steps.length === 0) return showError('Aucune étape dans le storyboard.');

  hideError();
  generatedImages = [];
  document.getElementById('galleryGrid').innerHTML = '';
  document.getElementById('btnGenerate').disabled = true;
  showStatus('Début de la génération...');
  renderProgressDots();

  for (let i = 0; i < steps.length; i++) {
    updateProgressDot(i, 'active');
    showStatus(`Étape ${i + 1}/${steps.length} — ${steps[i].name}...`);

    try {
      let imgUrl = null;
      if (motor === 'vertex') {
        imgUrl = await generateVertexImage(key, i);
      } else {
        imgUrl = await generateKieAiImage(key, i);
      }

      if (imgUrl) {
        generatedImages.push({ step: i, url: imgUrl, name: steps[i].name });
        appendGalleryCard(i, imgUrl);
        updateProgressDot(i, 'done');
      }
    } catch (err) {
      console.error(`Étape ${i+1} erreur:`, err);
      updateProgressDot(i, '');
      showError(`Erreur étape ${i+1}: ${err.message}`);
    }

    // Pause entre les appels
    if (i < steps.length - 1) await sleep(1500);
  }

  hideStatus();
  document.getElementById('btnGenerate').disabled = false;
  showStatus('✅ Séquence terminée !');
  setTimeout(hideStatus, 3000);
}

// ─────────────────────────────────────────────
// VERTEX AI IMAGE GENERATION
// ─────────────────────────────────────────────
async function generateVertexImage(key, stepIndex) {
  const step = steps[stepIndex];
  const prompt = buildImagePrompt(stepIndex, step);

  const endpoint = `https://aiplatform.googleapis.com/v1/projects/express/locations/us-central1/publishers/google/models/imagen-3.0-generate-002:predict?key=${key}`;

  const body = {
    instances: [{ prompt }],
    parameters: {
      sampleCount: 1,
      aspectRatio: '1:1',
      safetyFilterLevel: 'block_few',
      personGeneration: 'allow_adult'
    }
  };

  const res = await fetch(endpoint, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });

  if (!res.ok) {
    const err = await res.json();
    throw new Error(err.error?.message || 'Erreur Vertex Imagen');
  }

  const data = await res.json();
  const b64 = data.predictions?.[0]?.bytesBase64Encoded;
  if (!b64) throw new Error('Pas d\'image retournée');

  return 'data:image/png;base64,' + b64;
}

// ─────────────────────────────────────────────
// KIE.AI IMAGE GENERATION
// ─────────────────────────────────────────────
async function generateKieAiImage(key, stepIndex) {
  const step = steps[stepIndex];
  const prompt = buildImagePrompt(stepIndex, step);

  // Upload image d'inspiration en base64
  const inspiBase64 = images.inspi.split(',')[1];

  // 1. Upload image
  const uploadRes = await fetch('https://api.kie.ai/api/v1/image/upload', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${key}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ imageBase64: inspiBase64 })
  });
  if (!uploadRes.ok) throw new Error('kie.ai upload failed');
  const uploadData = await uploadRes.json();
  const imageUrl = uploadData.data?.url || uploadData.url;

  // 2. Create task
  const taskRes = await fetch('https://api.kie.ai/api/v1/image/createTask', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${key}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      model: 'gemini-3.1-flash-image-preview',
      prompt,
      imageUrl,
      width: 1024,
      height: 1024
    })
  });
  if (!taskRes.ok) throw new Error('kie.ai createTask failed');
  const taskData = await taskRes.json();
  const taskId = taskData.data?.taskId || taskData.taskId;

  // 3. Poll recordInfo
  for (let attempt = 0; attempt < 60; attempt++) {
    await sleep(3000);
    const pollRes = await fetch(`https://api.kie.ai/api/v1/image/recordInfo?taskId=${taskId}`, {
      headers: { 'Authorization': `Bearer ${key}` }
    });
    if (!pollRes.ok) continue;
    const pollData = await pollRes.json();
    const status = pollData.data?.status || pollData.status;
    if (status === 'completed' || status === 'success') {
      return pollData.data?.imageUrl || pollData.imageUrl;
    }
    if (status === 'failed') throw new Error('kie.ai génération échouée');
  }

  throw new Error('kie.ai timeout');
}

// ─────────────────────────────────────────────
// PROMPT BUILDER
// ─────────────────────────────────────────────
function buildImagePrompt(index, step) {
  const isFirst = index === 0;
  const isLast = index === steps.length - 1;

  // Personnes + vêtements
  const v1 = (document.getElementById('vetements-p1')?.value || '').trim();
  const v2 = (document.getElementById('vetements-p2')?.value || '').trim();

  let personDesc = '';
  if (images.p1 && images.p2) {
    personDesc = `PERSONNES : deux personnes présentes dans la scène — fidèles aux photos de référence uploadées.`;
    if (v1) personDesc += `\nPersonne 1 porte : ${v1}.`;
    if (v2) personDesc += `\nPersonne 2 porte : ${v2}.`;
  } else if (images.p1) {
    personDesc = `PERSONNE : une personne présente dans la scène — fidèle à la photo de référence uploadée.`;
    if (v1) personDesc += `\nElle porte : ${v1}.`;
  } else if (images.p2) {
    personDesc = `PERSONNE : une personne présente dans la scène — fidèle à la photo de référence uploadée.`;
    if (v2) personDesc += `\nElle porte : ${v2}.`;
  } else {
    personDesc = `PERSONNES : un couple de parents réalistes en train de faire des travaux.`;
  }

  const continuityNote = index > 0
    ? `CONTINUITÉ : même pièce, même palette de couleurs, même cadrage, même éclairage naturel que les scènes précédentes.`
    : `PIÈCE : début des travaux, espace quasi vide.`;

  return `RAW ULTRA-REALISTIC PHOTO, 4K resolution, zero AI filter, zero beautification, zero smoothing.
Shot on Sony A7R V, 35mm f/1.8, natural light, ISO 800, visible grain, unretouched skin texture, natural imperfections.

SCENE ${index + 1} : ${step.name}
${step.description}

${personDesc}

${continuityNote}
ROOM STATE : ${isFirst ? 'empty room, start of renovation' : isLast ? 'finished decorated child bedroom' : 'room mid-renovation, tools and materials visible'}

TECHNICAL REQUIREMENTS :
- 4K ultra-sharp, every detail crisp
- Real human proportions, no distortion
- Natural skin texture, visible pores, no airbrushing
- Authentic candid moment, not posed
- Warm natural window light, soft shadows
- Dust, paint traces, real work environment details

STRICTLY FORBIDDEN : blurry faces, missing limbs, text in image, CGI look, plastic skin, studio lighting, AI aesthetic.`;
}

// ─────────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────────
function appendGalleryCard(stepIndex, imgUrl) {
  const grid = document.getElementById('galleryGrid');
  const card = document.createElement('div');
  card.className = 'gallery-card';
  card.style.animationDelay = (stepIndex * 0.1) + 's';

  const img = document.createElement('img');
  img.src = imgUrl;
  img.alt = steps[stepIndex].name;

  const info = document.createElement('div');
  info.className = 'gallery-card-info';
  info.innerHTML = `
    <span class="gallery-step-label">${steps[stepIndex].name}</span>
    <span class="gallery-step-num">Étape ${stepIndex + 1}</span>
    <button class="btn-dl" onclick="downloadImage('${imgUrl}',${stepIndex})">↓</button>
  `;

  card.appendChild(img);
  card.appendChild(info);
  grid.appendChild(card);
}

function downloadImage(url, index) {
  const a = document.createElement('a');
  if (url.startsWith('data:')) {
    a.href = url;
  } else {
    // Blob pour les URL externes (Safari safe)
    fetch(url)
      .then(r => r.blob())
      .then(blob => {
        const blobUrl = URL.createObjectURL(blob);
        a.href = blobUrl;
        a.download = `studio-deco-etape-${index + 1}.jpg`;
        a.click();
        URL.revokeObjectURL(blobUrl);
      });
    return;
  }
  a.download = `studio-deco-etape-${index + 1}.jpg`;
  a.click();
}

// ─────────────────────────────────────────────
// PROGRESS DOTS
// ─────────────────────────────────────────────
function renderProgressDots() {
  const row = document.getElementById('progressRow');
  row.innerHTML = '';
  steps.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'progress-dot';
    dot.id = `dot-${i}`;
    row.appendChild(dot);
  });
}

function updateProgressDot(index, state) {
  const dot = document.getElementById(`dot-${index}`);
  if (!dot) return;
  dot.className = 'progress-dot' + (state ? ' ' + state : '');
}

// ─────────────────────────────────────────────
// UI HELPERS
// ─────────────────────────────────────────────
function showLoader(v) {
  document.getElementById('analyseLoader').classList.toggle('visible', v);
}

function showStatus(msg) {
  const bar = document.getElementById('statusBar');
  bar.classList.add('visible');
  document.getElementById('statusText').textContent = msg;
}

function hideStatus() {
  document.getElementById('statusBar').classList.remove('visible');
}

function showError(msg) {
  const el = document.getElementById('errorMsg');
  el.textContent = msg;
  el.classList.add('visible');
}

function hideError() {
  document.getElementById('errorMsg').classList.remove('visible');
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
