<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Studio Déco — Studio IRL</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5F0E8;
    --warm-white: #FAFAF7;
    --clay: #C4956A;
    --clay-dark: #A37850;
    --sage: #8A9E8C;
    --charcoal: #2C2C2A;
    --charcoal-light: #4A4A47;
    --dust: #E8E0D4;
    --dust-dark: #D4C9BA;
    --error: #C4614A;
    --success: #6B9E7A;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--charcoal);
    min-height: 100vh;
  }

  /* HEADER */
  header {
    background: var(--charcoal);
    padding: 18px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    color: var(--cream);
    letter-spacing: 0.5px;
  }
  .logo span { color: var(--clay); font-style: italic; }
  .badge {
    font-size: 11px;
    font-weight: 500;
    color: var(--clay);
    border: 1px solid var(--clay);
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* MAIN LAYOUT */
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: 6px;
  }
  .section-subtitle {
    font-size: 14px;
    color: var(--charcoal-light);
    margin-bottom: 32px;
    font-weight: 300;
  }

  /* MOTOR SELECTOR */
  .motor-bar {
    background: var(--charcoal);
    border-radius: 14px;
    padding: 20px 28px;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .motor-bar label {
    color: var(--cream);
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
  }
  .motor-tabs {
    display: flex;
    gap: 8px;
  }
  .motor-tab {
    padding: 8px 18px;
    border-radius: 8px;
    border: 1px solid #555;
    background: transparent;
    color: #aaa;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .motor-tab.active {
    background: var(--clay);
    border-color: var(--clay);
    color: white;
    font-weight: 500;
  }
  .motor-key-input {
    flex: 1;
    min-width: 200px;
    background: #3a3a38;
    border: 1px solid #555;
    border-radius: 8px;
    padding: 9px 14px;
    color: var(--cream);
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    outline: none;
  }
  .motor-key-input::placeholder { color: #666; }
  .motor-key-input:focus { border-color: var(--clay); }

  /* UPLOAD GRID */
  .upload-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  @media (max-width: 680px) {
    .upload-grid { grid-template-columns: 1fr; }
  }

  .upload-card {
    background: var(--warm-white);
    border: 2px dashed var(--dust-dark);
    border-radius: 16px;
    padding: 24px 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .upload-card:hover { border-color: var(--clay); background: #fdf8f3; }
  .upload-card.has-image { border-style: solid; border-color: var(--clay); }
  .upload-card input[type="file"] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
  .upload-icon {
    font-size: 36px;
    margin-bottom: 10px;
    display: block;
  }
  .upload-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 4px;
  }
  .upload-hint {
    font-size: 11px;
    color: #aaa;
  }
  .upload-preview {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 10px;
    display: none;
  }
  .upload-card.has-image .upload-preview { display: block; }
  .upload-card.has-image .upload-placeholder { display: none; }
  .upload-remove {
    position: absolute;
    top: 8px; right: 8px;
    background: var(--charcoal);
    color: white;
    border: none;
    border-radius: 50%;
    width: 24px; height: 24px;
    font-size: 13px;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }
  .upload-card.has-image .upload-remove { display: flex; }

  /* PERSON BLOCK */
  .person-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vetements-input {
    width: 100%;
    background: var(--warm-white);
    border: 1px solid var(--dust-dark);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    color: var(--charcoal);
    resize: none;
    outline: none;
    min-height: 64px;
    line-height: 1.5;
    transition: border-color 0.2s;
  }
  .vetements-input::placeholder { color: #bbb; }
  .vetements-input:focus { border-color: var(--clay); }

  /* INSPIRATION LARGE */
  .upload-card.inspiration {
    grid-column: 1 / -1;
    min-height: 240px;
    background: linear-gradient(135deg, #fdf8f3, #f5f0e8);
  }
  .upload-card.inspiration .upload-preview {
    height: 200px;
  }

  /* STORYBOARD */
  .storyboard-section {
    background: var(--warm-white);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 28px;
    display: none;
  }
  .storyboard-section.visible { display: block; }
  .storyboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .storyboard-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
  }
  .btn-regenerate {
    background: none;
    border: 1px solid var(--dust-dark);
    border-radius: 8px;
    padding: 7px 14px;
    font-size: 12px;
    cursor: pointer;
    color: var(--charcoal-light);
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
  }
  .btn-regenerate:hover { border-color: var(--clay); color: var(--clay); }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .step-item {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    gap: 12px;
    align-items: start;
    background: var(--cream);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .step-num {
    width: 32px; height: 32px;
    background: var(--clay);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .step-content { display: flex; flex-direction: column; gap: 6px; }
  .step-name {
    font-weight: 500;
    font-size: 14px;
    color: var(--charcoal);
  }
  .step-desc {
    font-size: 12px;
    color: var(--charcoal-light);
    line-height: 1.5;
    border: none;
    background: transparent;
    resize: none;
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    min-height: 40px;
  }
  .step-desc:focus {
    background: white;
    border-radius: 6px;
    padding: 6px;
    margin: -6px;
  }
  .step-delete {
    background: none;
    border: none;
    color: #ccc;
    cursor: pointer;
    font-size: 16px;
    padding: 4px;
    transition: color 0.2s;
    margin-top: 4px;
  }
  .step-delete:hover { color: var(--error); }

  .add-step-btn {
    margin-top: 12px;
    background: none;
    border: 1px dashed var(--dust-dark);
    border-radius: 8px;
    padding: 10px;
    width: 100%;
    font-size: 13px;
    color: var(--charcoal-light);
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
  }
  .add-step-btn:hover { border-color: var(--clay); color: var(--clay); }

  /* ACTIONS */
  .action-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .btn-primary {
    background: var(--clay);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 14px 28px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .btn-primary:hover { background: var(--clay-dark); transform: translateY(-1px); }
  .btn-primary:disabled { background: #ccc; cursor: not-allowed; transform: none; }
  .btn-secondary {
    background: var(--charcoal);
    color: var(--cream);
    border: none;
    border-radius: 10px;
    padding: 14px 28px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.2s;
  }
  .btn-secondary:hover { background: var(--charcoal-light); }
  .btn-secondary:disabled { background: #ccc; cursor: not-allowed; }

  /* STATUS */
  .status-bar {
    background: var(--charcoal);
    border-radius: 10px;
    padding: 14px 20px;
    color: var(--cream);
    font-size: 13px;
    margin-bottom: 24px;
    display: none;
    align-items: center;
    gap: 12px;
  }
  .status-bar.visible { display: flex; }
  .spinner {
    width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,0.2);
    border-top-color: var(--clay);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* PROGRESS */
  .progress-row {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .progress-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--dust-dark);
    transition: background 0.3s;
  }
  .progress-dot.done { background: var(--clay); }
  .progress-dot.active { background: var(--sage); animation: pulse 1s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

  /* GALLERY */
  .gallery-section { margin-top: 16px; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }
  .gallery-card {
    background: var(--warm-white);
    border-radius: 16px;
    overflow: hidden;
    animation: fadeUp 0.5s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .gallery-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }
  .gallery-card-info {
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .gallery-step-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--charcoal);
    flex: 1;
  }
  .gallery-step-num {
    font-size: 11px;
    color: var(--clay);
    font-weight: 600;
    background: #f5e8da;
    padding: 3px 8px;
    border-radius: 20px;
  }
  .btn-dl {
    background: var(--charcoal);
    color: white;
    border: none;
    border-radius: 7px;
    padding: 6px 12px;
    font-size: 11px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-dl:hover { background: var(--clay); }

  /* ERROR */
  .error-msg {
    background: #fdf0ed;
    border: 1px solid #e8c4bb;
    border-radius: 10px;
    padding: 14px 18px;
    color: var(--error);
    font-size: 13px;
    margin-bottom: 16px;
    display: none;
  }
  .error-msg.visible { display: block; }

  /* ANALYSE LOADER */
  .analyse-loader {
    text-align: center;
    padding: 40px;
    display: none;
  }
  .analyse-loader.visible { display: block; }
  .analyse-loader .spinner-big {
    width: 48px; height: 48px;
    border: 3px solid var(--dust);
    border-top-color: var(--clay);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 16px;
  }
  .analyse-text {
    font-size: 14px;
    color: var(--charcoal-light);
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  /* SEPARATOR */
  .sep {
    height: 1px;
    background: var(--dust);
    margin: 36px 0;
  }
</style>
</head>
<body>

<header>
  <div class="logo">Studio <span>Déco</span></div>
  <div class="badge">Studio IRL</div>
</header>

<div class="container">

  <!-- TITRE -->
  <h1 class="section-title">Racontez la création de la chambre</h1>
  <p class="section-subtitle">Uploadez l'inspiration + les photos des parents · Le studio génère les étapes de construction, image par image.</p>

  <!-- MOTEUR -->
  <div class="motor-bar">
    <label>Moteur :</label>
    <div class="motor-tabs">
      <button class="motor-tab active" onclick="setMotor('vertex')">Vertex AI</button>
      <button class="motor-tab" onclick="setMotor('kieai')">kie.ai</button>
    </div>
    <input class="motor-key-input" id="apiKeyInput" type="password" placeholder="Clé API AQ-... (Vertex AI)" />
  </div>

  <!-- UPLOADS -->
  <div class="upload-grid">

    <!-- Inspiration -->
    <div class="upload-card inspiration" id="card-inspi">
      <input type="file" accept="image/*" onchange="handleUpload(this,'inspi')" />
      <button class="upload-remove" onclick="removeImage(event,'inspi')">×</button>
      <img class="upload-preview" id="preview-inspi" />
      <div class="upload-placeholder">
        <span class="upload-icon">🏠</span>
        <div class="upload-label">Image d'inspiration</div>
        <div class="upload-hint">La chambre que vous souhaitez créer</div>
      </div>
    </div>

    <!-- Personne 1 -->
    <div class="person-block">
      <div class="upload-card" id="card-p1">
        <input type="file" accept="image/*" onchange="handleUpload(this,'p1')" />
        <button class="upload-remove" onclick="removeImage(event,'p1')">×</button>
        <img class="upload-preview" id="preview-p1" />
        <div class="upload-placeholder">
          <span class="upload-icon">👨</span>
          <div class="upload-label">Photo — Personne 1</div>
          <div class="upload-hint">Père, mère ou autre</div>
        </div>
      </div>
      <textarea class="vetements-input" id="vetements-p1" placeholder="Vêtements : ex. jean bleu, t-shirt blanc, baskets grises..."></textarea>
    </div>

    <!-- Personne 2 -->
    <div class="person-block">
      <div class="upload-card" id="card-p2">
        <input type="file" accept="image/*" onchange="handleUpload(this,'p2')" />
        <button class="upload-remove" onclick="removeImage(event,'p2')">×</button>
        <img class="upload-preview" id="preview-p2" />
        <div class="upload-placeholder">
          <span class="upload-icon">👩</span>
          <div class="upload-label">Photo — Personne 2</div>
          <div class="upload-hint">Optionnel</div>
        </div>
      </div>
      <textarea class="vetements-input" id="vetements-p2" placeholder="Vêtements : ex. robe fleurie, tablier beige, chaussures plates..."></textarea>
    </div>

  </div>

  <!-- BOUTON ANALYSER -->
  <div class="action-row">
    <button class="btn-primary" id="btnAnalyse" onclick="analyseInspiration()">
      ✨ Analyser et créer le storyboard
    </button>
  </div>

  <!-- LOADER ANALYSE -->
  <div class="analyse-loader" id="analyseLoader">
    <div class="spinner-big"></div>
    <div class="analyse-text">Gemini analyse votre inspiration...</div>
  </div>

  <!-- ERREUR -->
  <div class="error-msg" id="errorMsg"></div>

  <!-- STORYBOARD ÉDITABLE -->
  <div class="storyboard-section" id="storyboardSection">
    <div class="storyboard-header">
      <div class="storyboard-title">📋 Storyboard des étapes</div>
      <button class="btn-regenerate" onclick="analyseInspiration()">↺ Régénérer</button>
    </div>
    <div class="steps-list" id="stepsList"></div>
    <button class="add-step-btn" onclick="addStep()">+ Ajouter une étape</button>
  </div>

  <!-- BOUTON GÉNÉRER -->
  <div class="action-row" id="generateRow" style="display:none;">
    <button class="btn-secondary" id="btnGenerate" onclick="generateSequence()">
      🎬 Générer la séquence
    </button>
  </div>

  <!-- STATUS -->
  <div class="status-bar" id="statusBar">
    <div class="spinner"></div>
    <span id="statusText">Génération en cours...</span>
  </div>

  <!-- PROGRESS DOTS -->
  <div class="progress-row" id="progressRow"></div>

  <!-- GALLERY -->
  <div class="gallery-section" id="gallerySection">
    <div class="gallery-grid" id="galleryGrid"></div>
  </div>

</div>

<script>
// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
let motor = 'vertex';
let images = { inspi: null, p1: null, p2: null };
let steps = [];
let generatedImages = [];

// ─────────────────────────────────────────────
// MOTOR
// ─────────────────────────────────────────────
function setMotor(m) {
  motor = m;
  document.querySelectorAll('.motor-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  const inp = document.getElementById('apiKeyInput');
  inp.placeholder = m === 'vertex'
    ? 'Clé API AQ-... (Vertex AI)'
    : 'Clé API kie.ai';
}

function getApiKey() {
  return document.getElementById('apiKeyInput').value.trim();
}

// ─────────────────────────────────────────────
// UPLOAD
// ─────────────────────────────────────────────
function handleUpload(input, key) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    images[key] = e.target.result; // data URL
    document.getElementById('preview-' + key).src = e.target.result;
    document.getElementById('card-' + key).classList.add('has-image');
  };
  reader.readAsDataURL(file);
}

function removeImage(e, key) {
  e.stopPropagation();
  e.preventDefault();
  images[key] = null;
  document.getElementById('preview-' + key).src = '';
  document.getElementById('card-' + key).classList.remove('has-image');
}

// ─────────────────────────────────────────────
// STORYBOARD — ANALYSE VIA GEMINI
// ─────────────────────────────────────────────
async function analyseInspiration() {
  const key = getApiKey();
  if (!key) return showError('Veuillez entrer votre clé API.');
  if (!images.inspi) return showError("Veuillez uploader l'image d'inspiration.");

  hideError();
  showLoader(true);
  document.getElementById('storyboardSection').classList.remove('visible');
  document.getElementById('generateRow').style.display = 'none';

  try {
    const base64 = images.inspi.split(',')[1];
    const mimeMatch = images.inspi.match(/data:(image\/\w+);/);
    const mimeType = mimeMatch ? mimeMatch[1] : 'image/jpeg';

    // Préparer le contexte personnes
    let personContext = '';
    if (images.p1 && images.p2) personContext = 'deux personnes (père et mère)';
    else if (images.p1) personContext = 'une personne (père ou mère)';
    else if (images.p2) personContext = 'une personne (père ou mère)';

    const prompt = `Tu es un expert en décoration et travaux de chambre enfant. 
Analyse cette image d'inspiration de chambre enfant et génère un storyboard détaillé des étapes de travaux nécessaires pour créer cette chambre.
${personContext ? `Les images seront générées avec ${personContext} qui réalisent les travaux.` : ''}

IMPORTANT : Retourne UNIQUEMENT un JSON valide, sans markdown, sans backticks.

Format exact :
{
  "steps": [
    {
      "name": "Nom court de l'étape",
      "description": "Description détaillée de ce que fait/font la/les personne(s) dans cette scène, avec les couleurs, matériaux et ambiance visuelle observés dans l'image d'inspiration. Sois précis sur les gestes, les outils, les couleurs."
    }
  ]
}

Génère entre 5 et 8 étapes chronologiques réalistes (ex: préparation, peinture murs, pose du sol, montage meubles, installation literie, décoration, rangement, résultat final).
Chaque étape doit être une scène visuelle forte montrant les parents en action dans la chambre en construction.`;

    let responseText = '';

    if (motor === 'vertex') {
      responseText = await callVertexGemini(key, prompt, base64, mimeType);
    } else {
      // kie.ai ne fait pas d'analyse texte — on utilise un prompt par défaut
      steps = getDefaultSteps();
      renderStoryboard();
      showLoader(false);
      return;
    }

    const cleaned = responseText.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(cleaned);
    steps = parsed.steps || [];
    if (steps.length === 0) throw new Error('Aucune étape générée');
    renderStoryboard();

  } catch (err) {
    console.error(err);
    showError('Erreur d\'analyse : ' + err.message + '. Storyboard par défaut chargé.');
    steps = getDefaultSteps();
    renderStoryboard();
  }

  showLoader(false);
}

async function callVertexGemini(key, prompt, base64, mimeType) {
  // Vertex AI Express endpoint avec clé AQ
  const endpoint = `https://aiplatform.googleapis.com/v1/projects/express/locations/us-central1/publishers/google/models/gemini-2.0-flash:generateContent?key=${key}`;

  const body = {
    contents: [{
      role: 'user',
      parts: [
        { inline_data: { mime_type: mimeType, data: base64 } },
        { text: prompt }
      ]
    }],
    generationConfig: {
      temperature: 0.7,
      maxOutputTokens: 2048
    }
  };

  const res = await fetch(endpoint, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });

  if (!res.ok) {
    const err = await res.json();
    throw new Error(err.error?.message || 'Erreur Vertex AI');
  }

  const data = await res.json();
  return data.candidates?.[0]?.content?.parts?.[0]?.text || '';
}

